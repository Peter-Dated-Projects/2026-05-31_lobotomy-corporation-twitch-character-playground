# Copy to .env and fill in. The Twitch path is optional in dev mode.
# Get a token from https://twitchtokengenerator.com -- it returns BOTH an access
# token and a refresh token; paste each below. On startup the app validates the
# access token and, if it has expired, uses the refresh token to mint a new one
# and writes it back here automatically.
#
# SCOPES:
#   - chat:read                  -- read chat (the !say IRC path, chat/bot.py)
#   - channel:read:redemptions   -- receive Channel Points redemptions (robot TTS,
#                                   chat/eventsub.py). The token MUST belong to the
#                                   BROADCASTER (channel owner) for this to work.
TWITCH_CHANNEL=your_channel_name_here
TWITCH_ACCESS_TOKEN=your_access_token_here
TWITCH_REFRESH_TOKEN=your_refresh_token_here

# OPTIONAL. The custom-reward id whose redemptions drive the robot TTS. Leave
# unset to fire TTS for EVERY reward -- every redemption is logged with its
# reward_id either way, so run a redeem, copy the id from the console, then paste
# it here to lock the robot onto just that reward.
TWITCH_REWARD_ID=

# OPTIONAL. The custom-reward id for a "Change Speaker" reward. When set, the
# robot voice stops being random-per-message: one current speaker is locked in
# (the first message picks it at random), its robot stays on screen between
# messages, and it only changes when someone redeems THIS reward -- which picks a
# DIFFERENT random voice. Leave unset to use a fresh random voice on every
# message. Discover the id like TWITCH_REWARD_ID (redeem once, copy from the log).
TWITCH_REWARD_ID_COLOR_CHANGE=