# Copy to .env and fill in. The Twitch path is optional in dev mode.
# Get a token (with the chat:read scope) from https://twitchtokengenerator.com --
# it returns BOTH an access token and a refresh token; paste each below.
# On startup the app validates the access token and, if it has expired, uses the
# refresh token to mint a new one and writes it back here automatically.
TWITCH_CHANNEL=your_channel_name_here
TWITCH_ACCESS_TOKEN=your_access_token_here
TWITCH_REFRESH_TOKEN=your_refresh_token_here
